}
# final save list is what's now in env
final_save_list <- ls(envir = env)
tryCatch({
save(list = final_save_list, file = proj_file, envir = env)
message("Saved artifacts to: ", proj_file)
}, error = function(e){
message("Failed to save project_artifacts.RData: ", e$message)
})
# Also write selected objects as individual .rds files for selective loading
single_rds <- c("ci_tbl", "cal_plot", "xgb_pred_prob", "rf_pred_prob", "test_baked", "pred_prob")
single_rds <- single_rds[single_rds %in% final_save_list]
for (obj in single_rds) {
tryCatch({
saveRDS(get(obj, envir = env), file = file.path(artifacts_dir, paste0(obj, ".rds")))
message("Wrote ", obj, ".rds to ", artifacts_dir)
}, error = function(e){
message("Failed to write ", obj, ".rds : ", e$message)
})
}
}
