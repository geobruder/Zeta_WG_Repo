library(here)
library(yaml)
library(dplyr)
library(ggplot2)
library(pROC)
# Read config.yml to determine artifacts dir
cfg_file <- here::here("config.yml")
cfg <- if (file.exists(cfg_file)) yaml::read_yaml(cfg_file) else list(artifacts_dir = "Rmds/artifacts")
artifacts_dir <- cfg$artifacts_dir %||% "Rmds/artifacts"
if (!dir.exists(artifacts_dir)) dir.create(artifacts_dir, recursive = TRUE)
proj_file <- file.path(artifacts_dir, "project_artifacts.RData")
# Backup existing artifact file
if (file.exists(proj_file)) {
ts <- format(Sys.time(), "%Y%m%dT%H%M%S")
backup_file <- file.path(artifacts_dir, paste0("project_artifacts_backup_", ts, ".RData"))
tryCatch(file.copy(proj_file, backup_file, overwrite = TRUE), error = function(e) message("Backup failed: ", e$message))
}
# Load existing artifacts into temp env so we can preserve them
env <- new.env()
if (file.exists(proj_file)) tryCatch(load(proj_file, envir = env), error = function(e) message("Load existing artifacts failed: ", e$message))
# Determine canonical pred vector from global env or loaded env
pred_vec <- NULL; pred_name <- NULL
candidates <- c("platt_pred","pred_prob","xgb_pred_prob","raw_probs","rf_pred_prob","pred_enh_prob","pred_base_prob")
for (nm in candidates) {
if (exists(nm, envir = .GlobalEnv)) { pred_vec <- get(nm, envir = .GlobalEnv); pred_name <- nm; break }
if (exists(nm, envir = env)) { pred_vec <- get(nm, envir = env); pred_name <- nm; break }
}
# Prefer freshest test_baked (global then loaded)
tb <- NULL
if (exists("test_baked", envir = .GlobalEnv)) tb <- get("test_baked", envir = .GlobalEnv) else if (exists("test_baked", envir = env)) tb <- get("test_baked", envir = env)
# Attach canonical pred_prob and pred_decile only when safe
if (!is.null(tb) && !is.null(pred_vec) && is.data.frame(tb)) {
if (length(pred_vec) == nrow(tb)) {
if (!"pred_prob" %in% names(tb)) tb$pred_prob <- pred_vec
if ("pred_prob" %in% names(tb) && length(tb$pred_prob) == nrow(tb) && any(is.na(tb$pred_prob))) {
na_idx <- which(is.na(tb$pred_prob)); tb$pred_prob[na_idx] <- pred_vec[na_idx]
}
tb$pred_decile <- dplyr::ntile(tb$pred_prob, 10)
assign("test_baked", tb, envir = env)
assign("pred_prob", pred_vec, envir = env)
message("Attached canonical pred_prob (from ", pred_name, ") and pred_decile to test_baked in artifacts env.")
} else {
message("pred vector length (", length(pred_vec), ") does not match nrow(test_baked) (", nrow(tb), "); skipping attach.")
}
} else {
message("Either test_baked or a canonical pred vector is not present; skipping canonical attach.")
}
# Ensure cal_plot is a ggplot (rebuild from test_baked if necessary)
if (exists("cal_plot", envir = env) && !inherits(get("cal_plot", envir = env), "ggplot")) {
message("cal_plot in artifacts is not a ggplot; attempting to rebuild.")
if (exists("test_baked", envir = env)) {
tb2 <- get("test_baked", envir = env)
if (is.data.frame(tb2) && "pred_prob" %in% names(tb2) && "target_attrit" %in% names(tb2)) {
cal_df <- tb2 %>% mutate(bin = ntile(pred_prob, 10)) %>% group_by(bin) %>% summarise(mean_prob = mean(pred_prob, na.rm = TRUE), obs = mean(target_attrit, na.rm = TRUE), n = n(), .groups = "drop")
cal_plot <- ggplot2::ggplot(cal_df, ggplot2::aes(x = mean_prob, y = obs)) + ggplot2::geom_point(size = 2, color = "#2b8cbe") + ggplot2::geom_line(color = "#2b8cbe") + ggplot2::geom_abline(slope = 1, intercept = 0, linetype = "dashed") + ggplot2::theme_minimal()
assign("cal_plot", cal_plot, envir = env)
message("Rebuilt cal_plot as ggplot from test_baked and stored in artifacts env.")
} else {
cp <- get("cal_plot", envir = env)
if (is.data.frame(cp) && all(c("mean_prob","obs") %in% names(cp))) {
cal_plot <- ggplot2::ggplot(cp, ggplot2::aes(x = mean_prob, y = obs)) + ggplot2::geom_point(size = 2, color = "#2b8cbe") + ggplot2::geom_line(color = "#2b8cbe") + ggplot2::geom_abline(slope = 1, intercept = 0, linetype = "dashed") + ggplot2::theme_minimal()
assign("cal_plot", cal_plot, envir = env)
message("Converted cal_plot table into ggplot and stored in artifacts env.")
} else {
message("Cannot rebuild cal_plot: neither test_baked nor a cal table with mean_prob/obs found in artifacts env.")
}
}
} else {
message("cal_plot not ggplot and test_baked not present in artifacts env; skipping rebuild.")
}
} else {
message("cal_plot either already a ggplot in artifacts env or not present; no rebuild needed.")
}
# Recompute ROC objects from canonical test_baked if present
if (exists("test_baked", envir = env)) {
tb3 <- get("test_baked", envir = env)
if (is.data.frame(tb3) && "pred_prob" %in% names(tb3) && "target_attrit" %in% names(tb3)) {
truth <- tb3$target_attrit
if (!all(truth %in% c(0,1))) {
if (is.factor(truth)) truth <- as.numeric(as.character(truth))
if (is.character(truth)) truth <- ifelse(grepl("Attrited|1|Yes", truth, ignore.case = TRUE), 1, 0)
}
tryCatch({
roc_xgb_new <- pROC::roc(truth, tb3$pred_prob, quiet = TRUE)
assign("roc_xgb", roc_xgb_new, envir = env)
message("Recomputed roc_xgb from test_baked and stored in artifacts env.")
}, error = function(e) message("Failed to recompute roc_xgb: ", e$message))
if (exists("rf_pred_prob", envir = env) && length(get("rf_pred_prob", envir = env)) == nrow(tb3)) try(assign("roc_rf", pROC::roc(truth, get("rf_pred_prob", envir = env), quiet = TRUE), envir = env), silent = TRUE)
if (exists("pred_base_prob", envir = env) && length(get("pred_base_prob", envir = env)) == nrow(tb3)) try(assign("roc_base", pROC::roc(truth, get("pred_base_prob", envir = env), quiet = TRUE), envir = env), silent = TRUE)
if (exists("pred_enh_prob", envir = env) && length(get("pred_enh_prob", envir = env)) == nrow(tb3)) try(assign("roc_enh", pROC::roc(truth, get("pred_enh_prob", envir = env), quiet = TRUE), envir = env), silent = TRUE)
} else {
message("test_baked present but missing pred_prob or target_attrit; skipping ROC recompute.")
}
} else {
message("test_baked not present in artifacts env; skipping ROC recompute.")
}
# Build canonical save list and preserve existing objects
preferred_objects <- c("test_baked","platt_pred","pred_prob","raw_probs","xgb_pred_prob","rf_pred_prob","pred_base_prob","pred_enh_prob","rf_model","xgb_final","roc_base","roc_enh","roc_rf","roc_xgb","cal_plot","ci_tbl","pred_with_behav","pred_without_behav","top20_rf","top20_xgb")
existing_env_objs <- ls(envir = env)
existing_global_objs <- ls(envir = .GlobalEnv)
save_list <- unique(c(preferred_objects[preferred_objects %in% existing_env_objs], preferred_objects[preferred_objects %in% existing_global_objs]))
if (length(save_list) == 0) {
message("No artifact objects found to save in either environment. Nothing written.")
} else {
for (nm in setdiff(save_list, existing_env_objs)) if (nm %in% existing_global_objs) assign(nm, get(nm, envir = .GlobalEnv), envir = env)
final_save_list <- ls(envir = env)
tryCatch(save(list = final_save_list, file = proj_file, envir = env), error = function(e) message("Failed to save project_artifacts.RData: ", e$message))
single_rds <- c("ci_tbl","cal_plot","xgb_pred_prob","rf_pred_prob","test_baked","pred_prob")
single_rds <- single_rds[single_rds %in% final_save_list]
for (obj in single_rds) tryCatch(saveRDS(get(obj, envir = env), file = file.path(artifacts_dir, paste0(obj, ".rds"))), error = function(e) message("Failed to write ", obj, ".rds : ", e$message))
message("Saved canonical artifacts to: ", proj_file)
}
