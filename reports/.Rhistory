trControl = train_ctrl, metric = "ROC", tuneLength = 10)
# Extract nonzero coefficients at the best lambda
coef_glmnet <- coef(model_glmnet$finalModel, model_glmnet$bestTune$lambda)
selected_coefs <- coef_glmnet[coef_glmnet[,1] != 0, ]
selected_coefs_df <- as.data.frame(as.matrix(selected_coefs))
colnames(selected_coefs_df) <- "Coefficient"
