data_features <- data_clean %>%
# Create Age_Group using defined breaks
mutate(Age_Group = cut(Customer_Age,
breaks = c(18, 30, 45, 60, 100),
labels = c("18-30", "31-45", "46-60", "61+"),
right = FALSE),
# Recode Income_Category into ordinal groups (prefixing with order numbers)
Income_Category = recode(Income_Category,
"Less than $40K" = "1_Less40K",
"$40K - $60K" = "2_40to60",
"$60K - $80K" = "3_60to80",
"$80K - $120K" = "4_80to120",
"$120K +" = "5_120plus",
"Unknown" = "0_Unknown"),
# Other engineered features
Log_Total_Trans_Amt = log1p(Total_Trans_Amt),
High_Engagement = if_else(Contacts_Count_12_mon > median(Contacts_Count_12_mon, na.rm = TRUE) &
Total_Relationship_Count > median(Total_Relationship_Count, na.rm = TRUE),
TRUE, FALSE),
Relationship_Interaction = Months_on_book * Total_Relationship_Count)
# Define predictor variables (include new features: Age_Group)
predictor_vars <- c("Customer_Age", "Age_Group", "Gender", "Dependent_count", "Education_Level", "Marital_Status",
"Income_Category", "Card_Category", "Months_on_book", "Total_Relationship_Count",
"Months_Inactive_12_mon", "Contacts_Count_12_mon", "Credit_Limit", "Total_Revolving_Bal",
"Avg_Open_To_Buy", "Total_Amt_Chng_Q4_Q1", "Total_Trans_Amt", "Total_Trans_Ct",
"Total_Ct_Chng_Q4_Q1", "Avg_Utilization_Ratio", "High_Engagement",
"Relationship_Interaction", "Log_Total_Trans_Amt")
# Recode target and select predictors
data_model <- data_features %>%
mutate(Attrition_Flag = if_else(Attrition_Flag == "Existing Customer", "ExistingCustomer", "AttritedCustomer"),
Attrition_Flag = factor(Attrition_Flag, levels = c("ExistingCustomer", "AttritedCustomer"))) %>%
filter(!is.na(Attrition_Flag)) %>%
dplyr::select(PseudoID, Attrition_Flag, dplyr::all_of(predictor_vars)) %>%
tidyr::drop_na()
# Convert remaining character predictors to factors.
data_model <- data_model %>% mutate_if(is.character, as.factor)
# Dummy conversion (fullRank=TRUE)
predictor_columns <- setdiff(names(data_model), c("PseudoID", "Attrition_Flag"))
dummy_model <- dummyVars(~ ., data = data_model[, predictor_columns], fullRank = TRUE)
data_dummies <- as.data.frame(predict(dummy_model, newdata = data_model[, predictor_columns]))
names(data_dummies) <- make.names(names(data_dummies))
# Combine target, PseudoID, and dummies.
data_model_final <- cbind(data_model %>% dplyr::select(PseudoID, Attrition_Flag),
data_dummies)
# Display final data dimensions.
final_dims <- dim(data_model_final)
dims_df <- data.frame(Metric = c("Rows", "Columns"), Value = final_dims)
knitr::kable(dims_df, caption = "Final Model Data Dimensions", format = "latex", booktabs = TRUE) %>%
kableExtra::kable_styling(latex_options = c("striped", "hold_position"))
# Split into training (70%) and test (30%).
set.seed(123)
train_index <- createDataPartition(data_model_final$Attrition_Flag, p = 0.7, list = FALSE)
train_data_full <- data_model_final[train_index, ]
test_data_full  <- data_model_final[-train_index, ]
