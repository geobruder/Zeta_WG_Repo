temp_train <- data_features[1:500, ]
temp_train <- temp_train %>%
mutate(Attrition_Flag = if_else(Attrition_Flag == "Existing Customer",
"ExistingCustomer", "AttritedCustomer"),
Attrition_Flag = factor(Attrition_Flag, levels = c("ExistingCustomer", "AttritedCustomer")))
test_model <- glm(Attrition_Flag ~ ., data = temp_train, family = binomial,
control = glm.control(trace = TRUE, maxit = 50))
coef_table <- as.data.frame(summary(test_model)$coefficients)
library(knitr)
library(kableExtra)
knitr::kable(coef_table,
caption = "GLM Coefficients for Profiling Test Model",
format = "latex",
booktabs = TRUE) %>%
kableExtra::kable_styling(font_size = 4, latex_options = c("striped", "hold_position", "scale_down"))
cat("Profiling complete. Check the console for iteration messages.\n")
predictor_cols <- setdiff(names(data_features), c("CLIENTNUM", "PseudoID", "Attrition_Flag"))
data_matrix <- model.matrix(~ . - 1, data = data_features[, predictor_cols])
pca_preproc <- preProcess(data_matrix, method = c("center", "scale", "pca"), thresh = 0.95)
data_pca <- predict(pca_preproc, data_matrix)
pc_sd <- pca_preproc$std
pc_var <- pc_sd^2
prop_variance <- pc_var / sum(pc_var)
cum_variance <- cumsum(prop_variance)
pca_summary <- data.frame(
PC = paste0("PC", seq_along(pc_sd)),
Std_Dev = round(pc_sd, 3),
Variance_Explained = round(prop_variance, 3),
Cumulative_Variance = round(cum_variance, 3)
)
library(knitr)
library(kableExtra)
