# install.packages(c("httr","rvest","xml2","dplyr","purrr","kableExtra"))
library(httr)
library(rvest)
library(xml2)
library(dplyr)
library(purrr)
library(kableExtra)
# 1. scrape all classification codes from the Advanced Job Search page
search_url <- "https://www.calcareers.ca.gov/CalHRPublic/Jobs/JobList.aspx"
search_page <- read_html(GET(search_url))
all_codes <- search_page %>%
html_node("select#ddlClassficationCode") %>%
html_nodes("option") %>%
html_attr("value") %>%
discard(~ . == "")  # drop the blank option
# 2. helper functions
get_eligible_total <- function(code) {
url  <- "https://www.calcareers.ca.gov/CalHRPublic/EL_ExamEligibilityResults.aspx"
res  <- GET(url, query = list(classCode = code))
tbl  <- content(res, "text") %>% read_html() %>%
html_node("table.eligibilityTable") %>% html_text2()
nums <- str_extract_all(tbl, "\\d{1,3}(?:,\\d{3})*")[[1]] %>%
gsub(",", "", .) %>% as.integer()
sum(nums[1:4], na.rm=TRUE)
}
get_openings <- function(code) {
url  <- "https://www.calcareers.ca.gov/CalHRPublic/Jobs/JobList.aspx"
res  <- GET(url, query = list(classCode = code))
txt  <- content(res, "text") %>% read_html() %>%
html_node("#lblCount") %>% html_text2()
as.integer(str_extract(txt, "\\d+"))
}
# 3. build and analyze
results <- tibble(ClassCode = all_codes) %>%
mutate(
EligibleTotal = map_int(ClassCode, possibly(get_eligible_total, NA_integer_)),
Openings      = map_int(ClassCode, possibly(get_openings,      0))
) %>%
filter(Openings > 0, EligibleTotal > 0) %>%
mutate(VacancyRatio = Openings / EligibleTotal) %>%
arrange(desc(VacancyRatio))
# 4. display top 10 in a kableExtra table
results %>%
slice_head(n = 10) %>%
select(ClassCode, EligibleTotal, Openings, VacancyRatio) %>%
kbl(
col.names = c("Class Code", "Total Eligible", "Openings", "Vacancy ÷ Eligible"),
caption   = "Top 10 Classifications by Hire Likelihood"
) %>%
kable_styling(full_width = FALSE, position = "center") %>%
column_spec(4, format = "f", digits = 3)
