# Define bounding box for Minneapolis
bbox <- getbb("Minneapolis, Minnesota, USA")
# Grab major + local roads
roads <- opq(bbox) %>%
add_osm_feature(key = "highway",
value = c("motorway","primary","secondary",
"tertiary","residential")) %>%
osmdata_sf()
# Extract lines as an sf object
streets_sf <- roads$osm_lines
# Quick inspect
streets_sf
ggplot() +
# base streets
geom_sf(data = streets,
color = "grey80",
size  = 0.3) +
# walkshed fill
geom_sf(data = walkshed,
fill  = "#66c2a5",
alpha = 0.4,
color = NA) +
# highlight City Hall
geom_sf(data = city_hall,
color = "#238b45",
size  = 3) +
labs(
title    = "500 m Walk-shed around Minneapolis City Hall",
subtitle = "Streets + buffer (linear Euclidean)",
caption  = "Data: OpenStreetMap via osmdata"
) +
theme_minimal() +
theme(
panel.grid.minor = element_blank(),
panel.grid.major = element_line(color = "white", size = 0.2)
)
