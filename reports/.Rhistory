caption = paste("PCA Summary. Reduced Dimensions:", ncol(data_pca)),
format = "latex",
booktabs = TRUE) %>%
kable_styling(latex_options = c("striped", "hold_position", "scale_down"))
cat("PCA applied. Reduced dimensions:", ncol(data_pca), "\n")
